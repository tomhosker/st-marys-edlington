extends layout

mixin to-two-digit(number)
    if number > 9
        | #{number}
    else
        | 0#{number}

block content
    sidebox.liturgical-border
        h2 Parish Priest
        p #[b #{data.parishPriest.full_name}]
            br
            | #[i Presbytery] &nbsp; #{data.parishPriest.landline}
            br
            | #[i Mobile] &nbsp; #{data.parishPriest.mobile}
            br
            | #[i Email] &nbsp; #{data.parishPriest.email}
            br
            | #[i Post] &nbsp; #{data.parishPriest.address_name}

        h2 Locations
        for location in data.locations
            p #[b #{location.house_name}]
                br
                | #{location.house_number} #{location.road_name}
                br
                | #{location.town}
                br
                | #{location.post_town}
                br
                | #{location.postcode}
                br

    h1 Service Times

    table.homepage
        tr
            th Service
            th Time
            th Location
        for service in data.serviceTimes
            tr
                td=service.service_type
                td
                    +to-two-digit(service.hours)
                    |:
                    +to-two-digit(service.minutes)
                td=service.location_name

    div.slideshows-container
        div.slideshow-container
            div.mySlides.fade
                img.slideshow(src="/images/slideshows/st_marys/1.jpg")
            div.mySlides.fade
                img.slideshow(src="/images/slideshows/st_marys/2.jpg")
            div.mySlides.fade
                img.slideshow(src="/images/slideshows/st_marys/3.jpg")
            div.mySlides.fade
                img.slideshow(src="/images/slideshows/st_marys/4.jpg")

    if isAdmin
        h2 Hidden Area
        ul
            li #[a(href="/admin") Admin area]

    h2 Welcome
    p On behalf of the parish of #[b St Mary's Edlington], welcome! We are a community based in the #[b Doncaster] area, who gather regularly to worship, to receive the sacraments, to announce the gospel, and to support each other in following #[b Jesus Christ]. Our church services are #[b open to all], and we strive to create communities where all will feel welcome.

    script(type="text/javascript", src="/frontend_scripts/slideshow.js")
